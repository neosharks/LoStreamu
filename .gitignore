# App runtime — never commit these
app/node_modules/
app/config.json
app/secrets.json
app/meta-cache.json
app/server.log
app/cookies.txt
app/media/*
!app/media/.gitkeep
app/thumbnails/*.jpg
app/thumbnails/*.vtt
!app/thumbnails/.gitkeep

# NOTE: streamvault-app.tar.gz IS committed on purpose (the installer pulls it).
